{
    "name": "caremillc/framework",
    "description": "Caremi php framework",
    "type": "library",
    "license": "MIT",
    "homepage": "https://caremi.com",
    "support": {
        "issues": "https://github.com/caremillc/caremi/issues",
        "source": "https://github.com/caremillc/caremi"
    },
    "authors": [
        {
            "name": "ikoncoders",
            "email": "caremillc@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "ext-ctype": "*",
        "ext-filter": "*",
        "ext-hash": "*",
        "ext-mbstring": "*",
        "ext-openssl": "*",
        "ext-session": "*",
        "ext-tokenizer": "*",
		"nikic/fast-route": "dev-master",
        "psr/container": "2.0.x-dev",
        "league/container": "^4.0.0",
        "symfony/dotenv": "^6.0",
        "twig/twig": "^3.0",
        "doctrine/dbal": "^3.6",
        "psr/event-dispatcher": "^1.0"
    },
    "require-dev": {
       "symfony/var-dumper": "6.3.x-dev",
        "phpunit/phpunit": "10.1"
    },
    "autoload": {
        "psr-4": {
            "Careminate\\": "Careminate/",
            "Careminate\\Support\\": "Careminate/Support/"
        },
        "files": [
            "Careminate/Support/helpers.php"
        ]
    },
    "autoload-dev": {
        "files": [],
        "psr-4": {
            "Careminate\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {}
    },
    "suggest": {},
    "conflict": {},
    "provide": {},
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "composer/package-versions-deprecated": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
     "version": "1.0"
   
}